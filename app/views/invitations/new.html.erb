<% content_for :title, "Invite a member" %>

<div class="max-w-lg mx-auto">
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-gray-900">Invite a member</h1>
    <p class="text-sm text-gray-500 mt-0.5">They'll receive an email with a link to join <%= current_academy.name %>.</p>
  </div>

  <%= form_with model: @invitation, url: invitations_path, class: "bg-white rounded-xl border border-gray-200 p-6 space-y-5" do |f| %>

    <div>
      <%= f.label :email, "Email address", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.email_field :email,
            placeholder: "coach@example.com",
            class: "input-field",
            autofocus: true %>
    </div>

    <div>
      <%= f.label :role, "Role", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.select :role,
            options_for_select([
              ["Member — coaches and staff (read + scoped write)", "member"],
              ["Admin — manage operations, invite members", "admin"],
              ["Owner — full access including settings", "owner"]
            ], "member"),
            {}, class: "input-field" %>
    </div>

    <% if @invitation.errors.any? %>
      <ul class="text-sm text-red-600 space-y-1 list-disc list-inside bg-red-50 border border-red-200 rounded-lg px-4 py-3">
        <% @invitation.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    <% end %>

    <div class="flex gap-3 pt-1">
      <%= f.submit "Send invitation",
            class: "px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <%= link_to "Cancel", memberships_path,
            class: "px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>
