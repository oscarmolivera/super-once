<h2 class="text-2xl font-bold mb-6">Choose Your Plan</h2>

<%= form_with model: @form, url: onboarding_step_3_path, method: :post, class: "space-y-6" do |f| %>
  <% if @form.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(@form.errors.count, 'error') %> prevented saving:
      </h3>
      <ul class="list-disc pl-5 text-sm text-red-700">
        <% @form.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <% @plans.each do |plan| %>
      <label class="relative flex flex-col p-6 border-2 border-gray-200 rounded-lg cursor-pointer hover:border-indigo-400 transition <%= 'border-indigo-600 bg-indigo-50' if @form.plan_id == plan.id.to_s %>">
        <div class="flex items-start mb-4">
          <%= f.radio_button :plan_id, plan.id, class: "w-4 h-4 mt-1" %>
          <div class="ml-4 flex-1">
            <h3 class="text-lg font-semibold text-gray-900 capitalize"><%= plan.name %></h3>
            <p class="text-2xl font-bold text-gray-900 mt-2">
              <% if plan.free? %>
                Free
              <% else %>
                $<%= plan.price_amount %><span class="text-sm text-gray-600">/mo</span>
              <% end %>
            </p>
            <% if !plan.free? %>
              <p class="text-sm text-gray-500 mt-1"><%= plan.trial_days %> day free trial</p>
            <% end %>
          </div>
        </div>

        <div class="space-y-2 mt-4 pt-4 border-t border-gray-300">
          <% plan.features_array.each do |feature| %>
            <div class="flex items-center text-sm">
              <svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <%= feature %>
            </div>
          <% end %>
        </div>
      </label>
    <% end %>
  </div>

  <div class="flex gap-4 pt-6">
    <%= link_to "Back", onboarding_step_2_path, class: "px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50" %>
    <%= f.submit "Next", class: "flex-1 px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700" %>
  </div>
<% end %>
