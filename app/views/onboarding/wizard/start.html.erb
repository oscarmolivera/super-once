<div class="text-center mb-12">
  <h2 class="text-3xl font-bold text-gray-900 mb-4">Get Started Today</h2>
  <p class="text-lg text-gray-600 mb-8">Choose a plan and set up your academy</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <% @plans.each do |plan| %>
    <%= link_to onboarding_step_1_path, class: "flex flex-col p-6 border-2 border-gray-200 rounded-lg hover:border-indigo-400 hover:shadow-lg transition cursor-pointer" do %>
      <h3 class="text-lg font-semibold text-gray-900 capitalize"><%= plan.name %></h3>
      <p class="text-2xl font-bold text-gray-900 mt-2">
        <% if plan.free? %>
          Free
        <% else %>
          $<%= plan.price_amount %><span class="text-sm text-gray-600">/mo</span>
        <% end %>
      </p>
      <% if !plan.free? %>
        <p class="text-sm text-gray-500 mt-1"><%= plan.trial_days %> day free trial</p>
      <% end %>

      <div class="space-y-2 mt-4 pt-4 border-t border-gray-300 flex-1">
        <% plan.features_array.each do |feature| %>
          <div class="flex items-center text-sm text-gray-600">
            <svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <%= feature %>
          </div>
        <% end %>
      </div>

      <div class="mt-6 px-4 py-2 bg-indigo-600 text-white rounded-lg text-center font-medium">
        Get Started
      </div>
    <% end %>
  <% end %>
</div>

<div class="bg-gray-50 rounded-lg p-6 text-center">
  <p class="text-gray-600">
    Have questions? <a href="/contact" class="text-indigo-600 hover:text-indigo-700 font-medium">Contact our support team</a>
  </p>
</div>
