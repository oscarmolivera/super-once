<% content_for :title, "Edit settings" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-gray-900">Edit academy settings</h1>
    <p class="text-sm text-gray-500 mt-0.5">Changes apply immediately across the whole academy.</p>
  </div>

  <%= form_with model: @academy, url: academy_settings_path, method: :patch,
        class: "space-y-6" do |f| %>

    <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-gray-900">Basic information</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <%= f.label :name, "Academy name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :name, class: "input-field" %>
        </div>
        <div>
          <%= f.label :sport_type, "Sport", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.select :sport_type,
                options_for_select([["Soccer", "soccer"], ["Futsal", "futsal"], ["Basketball", "basketball"], ["Other", "other"]], @academy.sport_type),
                {}, class: "input-field" %>
        </div>
      </div>

      <div>
        <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_area :description, rows: 3,
              placeholder: "Tell players and parents about your academy…",
              class: "input-field resize-none" %>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-gray-900">Contact &amp; location</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <%= f.label :city, "City", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :city, class: "input-field" %>
        </div>
        <div>
          <%= f.label :country, "Country", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :country, class: "input-field" %>
        </div>
        <div>
          <%= f.label :phone, "Phone", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.telephone_field :phone, class: "input-field" %>
        </div>
        <div>
          <%= f.label :website, "Website", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.url_field :website, placeholder: "https://", class: "input-field" %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-gray-900">Brand</h2>
      <div>
        <%= f.label :primary_color, "Brand colour", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <div class="flex items-center gap-3">
          <%= f.color_field :primary_color, class: "h-9 w-16 rounded-lg border border-gray-300 cursor-pointer p-0.5" %>
          <span class="text-xs text-gray-400">Used in the sidebar and emails</span>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Save settings",
            class: "px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <%= link_to "Cancel", academy_settings_path,
            class: "px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900" %>
    </div>

  <% end %>
</div>
