<% content_for :title, "Dashboard" %>

<div class="max-w-5xl mx-auto">

  <%# Header %>
  <div class="mb-8">
    <h1 class="text-2xl font-semibold text-gray-900">
      Welcome<%# if current_user.full_name %>, <%#= current_user.full_name.split.first %><%# end %>
    </h1>
    <p class="text-sm text-gray-500 mt-1">
      <%= current_academy.name %>
      <span class="mx-1.5 text-gray-300">&middot;</span>
      <span class="capitalize"><%= current_academy.plan %> plan</span>
      <span class="mx-1.5 text-gray-300">&middot;</span>
      <span class="capitalize <%= current_academy.status_active? ? 'text-green-600' : 'text-amber-600' %>">
        <%= current_academy.status %>
      </span>
    </p>
  </div>

  <%# Stat cards %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Members</p>
      <p class="text-2xl font-semibold text-gray-900"><%= @members_count %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Employees</p>
      <p class="text-2xl font-semibold text-gray-900"><%= @employees_count %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Players</p>
      <p class="text-2xl font-semibold text-gray-900"><%= @players_count %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Cups</p>
      <p class="text-2xl font-semibold text-gray-900"><%= @cups_count %></p>
    </div>
  </div>

  <%# Three pillar cards %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">

    <%= link_to enterprise_root_path,
          class: "group bg-white rounded-xl border border-gray-200 p-6 hover:border-indigo-200 hover:shadow-sm transition-all relative overflow-hidden" do %>
      <div class="absolute inset-0 bg-indigo-50 opacity-0 group-hover:opacity-30 transition-opacity rounded-xl"></div>
      <div class="relative">
        <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/>
          </svg>
        </div>
        <h2 class="text-base font-semibold text-gray-900 mb-1">Enterprise</h2>
        <p class="text-sm text-gray-500 leading-relaxed">Staff, payroll, finances &amp; inventory</p>
        <p class="mt-3 text-xs text-indigo-500 font-medium group-hover:underline">Open &rarr;</p>
      </div>
    <% end %>

    <%= link_to school_root_path,
          class: "group bg-white rounded-xl border border-gray-200 p-6 hover:border-teal-200 hover:shadow-sm transition-all relative overflow-hidden" do %>
      <div class="absolute inset-0 bg-teal-50 opacity-0 group-hover:opacity-30 transition-opacity rounded-xl"></div>
      <div class="relative">
        <div class="w-10 h-10 rounded-xl bg-teal-50 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
          </svg>
        </div>
        <h2 class="text-base font-semibold text-gray-900 mb-1">School</h2>
        <p class="text-sm text-gray-500 leading-relaxed">Players, categories, practice &amp; training</p>
        <p class="mt-3 text-xs text-teal-500 font-medium group-hover:underline">Open &rarr;</p>
      </div>
    <% end %>

    <%= link_to club_root_path,
          class: "group bg-white rounded-xl border border-gray-200 p-6 hover:border-amber-200 hover:shadow-sm transition-all relative overflow-hidden" do %>
      <div class="absolute inset-0 bg-amber-50 opacity-0 group-hover:opacity-30 transition-opacity rounded-xl"></div>
      <div class="relative">
        <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/>
          </svg>
        </div>
        <h2 class="text-base font-semibold text-gray-900 mb-1">Club</h2>
        <p class="text-sm text-gray-500 leading-relaxed">Cups, tournaments &amp; teams</p>
        <p class="mt-3 text-xs text-amber-500 font-medium group-hover:underline">Open &rarr;</p>
      </div>
    <% end %>

  </div>

  <%# Quick links footer row %>
  <div class="flex items-center gap-6 text-sm text-gray-400">
    <%= link_to "Members (#{@members_count})", memberships_path, class: "hover:text-gray-700 transition-colors" %>
    <% if policy(current_academy).settings_edit? %>
      <%= link_to "Settings", edit_academy_settings_path, class: "hover:text-gray-700 transition-colors" %>
    <% end %>
    <%= link_to "My profile", profile_path, class: "hover:text-gray-700 transition-colors" %>
    <span class="ml-auto text-xs"><%= current_academy.full_domain %></span>
  </div>

</div>
