<% content_for :title, "Dashboard" %>

<div class="max-w-5xl mx-auto">

  <%# Page header %>
  <div class="mb-8">
    <h1 class="text-2xl font-semibold text-gray-900">Welcome back<% if current_user.full_name %>, <%= current_user.full_name.split.first %><% end %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= current_academy.name %> · <span class="capitalize"><%= current_academy.plan %> plan</span></p>
  </div>

  <%# Three pillar cards %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">

    <%= link_to enterprise_root_path, class: "group relative bg-white rounded-xl border border-gray-200 p-6 hover:border-indigo-300 hover:shadow-sm transition-all" do %>
      <div class="w-10 h-10 rounded-lg bg-indigo-50 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/>
        </svg>
      </div>
      <h2 class="text-base font-semibold text-gray-900 mb-1">Enterprise</h2>
      <p class="text-sm text-gray-500">Staff, payroll, income &amp; expenses, inventory</p>
      <div class="mt-4 text-xs text-gray-400"><%= @employees_count %> employees</div>
      <span class="absolute top-5 right-5 text-gray-300 group-hover:text-indigo-400 transition-colors text-lg">&rarr;</span>
    <% end %>

    <%= link_to school_root_path, class: "group relative bg-white rounded-xl border border-gray-200 p-6 hover:border-teal-300 hover:shadow-sm transition-all" do %>
      <div class="w-10 h-10 rounded-lg bg-teal-50 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
        </svg>
      </div>
      <h2 class="text-base font-semibold text-gray-900 mb-1">School</h2>
      <p class="text-sm text-gray-500">Players, categories, practices, training</p>
      <div class="mt-4 text-xs text-gray-400"><%= @players_count %> players</div>
      <span class="absolute top-5 right-5 text-gray-300 group-hover:text-teal-400 transition-colors text-lg">&rarr;</span>
    <% end %>

    <%= link_to club_root_path, class: "group relative bg-white rounded-xl border border-gray-200 p-6 hover:border-amber-300 hover:shadow-sm transition-all" do %>
      <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/>
        </svg>
      </div>
      <h2 class="text-base font-semibold text-gray-900 mb-1">Club</h2>
      <p class="text-sm text-gray-500">Cups, tournaments, team configuration</p>
      <div class="mt-4 text-xs text-gray-400"><%= @cups_count %> cups registered</div>
      <span class="absolute top-5 right-5 text-gray-300 group-hover:text-amber-400 transition-colors text-lg">&rarr;</span>
    <% end %>

  </div>

  <%# Members summary %>
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-gray-900">Team members</h2>
      <% if policy(Membership).new? %>
        <%= link_to "Add member", new_membership_path,
              class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" %>
      <% end %>
    </div>
    <p class="text-2xl font-semibold text-gray-900"><%= @members_count %></p>
    <p class="text-sm text-gray-500 mt-1">People with access to this dashboard</p>
  </div>

</div>
