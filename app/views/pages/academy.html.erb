<%# Public-facing landing for academy.nubbe.net/welcome — uses marketing layout %>
<% content_for :title, @academy.name %>

<section class="max-w-3xl mx-auto px-6 py-20 text-center">
  <div class="w-16 h-16 rounded-2xl mx-auto mb-6 flex items-center justify-center text-white text-2xl font-bold"
       style="background-color: <%= @academy.primary_color || '#4f46e5' %>">
    <%= @academy.name.first.upcase %>
  </div>

  <h1 class="text-4xl font-bold text-gray-900 mb-4"><%= @academy.name %></h1>

  <% if @academy.description.present? %>
    <p class="text-lg text-gray-500 mb-8 leading-relaxed"><%= @academy.description %></p>
  <% end %>

  <div class="flex items-center justify-center gap-6 text-sm text-gray-400 mb-10">
    <% if @academy.city.present? %>
      <span><%= @academy.city %></span>
    <% end %>
    <span class="capitalize"><%= @academy.sport_type %> Academy</span>
  </div>

  <%= link_to "Member login", new_session_path,
        class: "inline-block px-6 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition-colors" %>
</section>
