<% content_for :title, "SuperOnce — Academy Management Platform" %>

<%# Hero %>
<section class="max-w-5xl mx-auto px-6 pt-20 pb-24 text-center">
  <span class="inline-block mb-4 px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-xs font-semibold tracking-wide uppercase">Built for sport academies</span>
  <h1 class="text-5xl font-bold text-gray-900 leading-tight mb-6">
    Run your academy<br>from one place
  </h1>
  <p class="text-xl text-gray-500 max-w-2xl mx-auto mb-10">
    SuperOnce gives soccer and futsal academies the tools to manage staff, players, training and tournaments — all under one roof.
  </p>
  <div class="flex items-center justify-center gap-4">
    <a href="#" class="px-6 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition-colors">
      Start free trial
    </a>
    <a href="<%= pricing_path %>" class="px-6 py-3 text-gray-700 font-semibold rounded-xl border border-gray-200 hover:bg-gray-50 transition-colors">
      See pricing
    </a>
  </div>
</section>

<%# Three pillar feature blocks %>
<section class="bg-gray-50 border-y border-gray-100 py-20">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-2xl font-bold text-gray-900 text-center mb-12">Everything your academy needs</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <div class="bg-white rounded-2xl border border-gray-200 p-8">
        <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Enterprise</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Staff management, payroll, income &amp; expenses, inventory and compliance documents.</p>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 p-8">
        <div class="w-10 h-10 rounded-xl bg-teal-50 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">School</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Player registration, category management, practice scheduling and attendance tracking.</p>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 p-8">
        <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Club</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Cup registrations, tournament team configuration and match results tracking.</p>
      </div>

    </div>
  </div>
</section>
