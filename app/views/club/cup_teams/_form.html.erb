<%= form_with model: [:club, @cup_team], class: "space-y-4" do |f| %>
  <% if @cup_team.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      <div class="font-semibold mb-1">Please fix the following:</div>
      <ul class="list-disc pl-5">
        <% @cup_team.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :tournament_id, "Tournament", class: "block text-sm font-medium text-gray-700" %>
    <%= f.collection_select :tournament_id, policy_scope(Tournament).includes(:cup).order(year: :desc), :id, :display_name,
      { prompt: "Select a tournament" },
      class: "mt-1 block w-full rounded-lg border-gray-300" %>
    <p class="text-xs text-gray-500 mt-1">Tip: after selecting, you can rename the squad below.</p>
  </div>

  <div>
    <%= f.label :category_id, "Category", class: "block text-sm font-medium text-gray-700" %>
    <%= f.collection_select :category_id, policy_scope(Category).order(:name), :id, :name,
      { prompt: "Select a category" },
      class: "mt-1 block w-full rounded-lg border-gray-300" %>
  </div>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border-gray-300" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <%= link_to "Cancel", club_cup_teams_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>

