<% content_for :title, "Roster" %>

<div class="max-w-5xl mx-auto">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-xl font-semibold text-gray-900">Roster</h1>
      <p class="text-sm text-gray-500">
        <%= @cup_team.name %>
        <span class="text-gray-400">·</span>
        <%= @cup_team.category.name %>
      </p>
    </div>
    <%= link_to "Back", club_cup_team_path(@cup_team), class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>

  <%= form_with url: roster_club_cup_team_path(@cup_team), method: :patch, class: "space-y-4" do %>
    <div class="rounded-xl border border-gray-200 bg-white divide-y divide-gray-100">
      <% @players.each do |player| %>
        <% tp = @existing[player.id] %>
        <div class="p-4 grid grid-cols-1 md:grid-cols-12 gap-3 items-center">
          <div class="md:col-span-1">
            <input type="checkbox" name="selected_player_ids[]" value="<%= player.id %>" <%= "checked" if tp.present? %> class="rounded border-gray-300" />
          </div>
          <div class="md:col-span-5 text-sm font-medium text-gray-900">
            <%= player.last_name %>, <%= player.first_name %>
          </div>
          <div class="md:col-span-3">
            <input type="number" name="roster[<%= player.id %>][jersey_number]" value="<%= tp&.jersey_number %>" placeholder="Jersey #"
              class="block w-full rounded-lg border-gray-300 text-sm" />
          </div>
          <div class="md:col-span-3">
            <input type="text" name="roster[<%= player.id %>][position]" value="<%= tp&.position %>" placeholder="Position"
              class="block w-full rounded-lg border-gray-300 text-sm" />
          </div>
        </div>
      <% end %>

      <% if @players.empty? %>
        <div class="p-6 text-sm text-gray-500">No players enrolled in this category.</div>
      <% end %>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Save roster</button>
      <%= link_to "Cancel", club_cup_team_path(@cup_team), class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>

