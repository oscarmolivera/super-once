<% cup = @cup || @tournament.cup %>
<%= form_with model: @tournament, url: (@tournament.persisted? ? club_tournament_path(@tournament) : club_cup_tournaments_path(cup)), class: "space-y-4" do |f| %>
  <% if @tournament.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      <div class="font-semibold mb-1">Please fix the following:</div>
      <ul class="list-disc pl-5">
        <% @tournament.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :year, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :year, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
    <div>
      <%= f.label :location, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :location, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :starts_on, class: "block text-sm font-medium text-gray-700" %>
      <%= f.date_field :starts_on, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
    <div>
      <%= f.label :ends_on, class: "block text-sm font-medium text-gray-700" %>
      <%= f.date_field :ends_on, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <%= link_to "Cancel", (@tournament.persisted? ? club_tournament_path(@tournament) : club_cup_path(cup)), class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>

