    </div>
    <p class="text-sm text-gray-500">Cups, tournaments and competitive team management. Coming in Phase 5.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <%= render "shared/coming_soon_card", title: "Cups",           description: "Annual competitions the academy participates in" %>
    <%= render "shared/coming_soon_card", title: "Tournaments",    description: "Yearly editions of each cup" %>
    <%= render "shared/coming_soon_card", title: "Cup teams",      description: "Register squads from your categories" %>
    <%= render "shared/coming_soon_card", title: "Matches",        description: "Fixtures and results" %>
  </div>
