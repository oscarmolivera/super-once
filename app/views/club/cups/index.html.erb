<% content_for :title, "Cups" %>

<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-900">Cups</h1>
    <% if policy(Cup.new(academy: current_academy)).new? %>
      <%= link_to "New cup", new_club_cup_path, class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <% end %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white divide-y divide-gray-100">
    <% @cups.each do |cup| %>
      <div class="p-4 flex items-center">
        <div>
          <div class="text-sm font-medium text-gray-900">
            <%= link_to cup.name, club_cup_path(cup), class: "hover:underline" %>
          </div>
          <div class="text-xs text-gray-500">
            <%= cup.sport_type %>
            <% if cup.organizer.present? %>
              <span class="text-gray-400">·</span>
              <%= cup.organizer %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if @cups.empty? %>
      <div class="p-6 text-sm text-gray-500">No cups yet.</div>
    <% end %>
  </div>
</div>

