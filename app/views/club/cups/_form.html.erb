<%= form_with model: [:club, @cup], class: "space-y-4" do |f| %>
  <% if @cup.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      <div class="font-semibold mb-1">Please fix the following:</div>
      <ul class="list-disc pl-5">
        <% @cup.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border-gray-300" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :sport_type, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :sport_type, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
    <div>
      <%= f.label :organizer, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :organizer, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :recurring, class: "rounded border-gray-300" %>
    <%= f.label :recurring, "Recurring (annual)", class: "text-sm text-gray-700" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <%= link_to "Cancel", club_cups_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>

