<% content_for :title, @cup.name %>

<div class="max-w-5xl mx-auto">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-xl font-semibold text-gray-900"><%= @cup.name %></h1>
      <p class="text-sm text-gray-500">
        <%= @cup.sport_type %>
        <% if @cup.organizer.present? %>
          <span class="text-gray-400">·</span>
          <%= @cup.organizer %>
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% if policy(@cup).edit? %>
        <%= link_to "Edit", edit_club_cup_path(@cup), class: "rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-50" %>
      <% end %>
      <% if policy(@cup).destroy? %>
        <%= button_to "Delete", club_cup_path(@cup), method: :delete, data: { turbo_confirm: "Delete this cup?" }, class: "rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-500" %>
      <% end %>
    </div>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-gray-900">Tournaments</h2>
      <% if policy(Tournament.new(academy: current_academy, cup: @cup, year: Date.current.year)).new? %>
        <%= link_to "New tournament", new_club_cup_tournament_path(@cup), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
      <% end %>
    </div>

    <% if @tournaments.any? %>
      <div class="divide-y divide-gray-100">
        <% @tournaments.each do |t| %>
          <div class="py-2 flex items-center">
            <div class="text-sm text-gray-900">
              <%= link_to "#{t.year}", club_tournament_path(t), class: "font-medium hover:underline" %>
              <% if t.location.present? %>
                <span class="text-gray-400">·</span>
                <span class="text-gray-600"><%= t.location %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No tournaments yet.</p>
    <% end %>
  </div>
</div>

