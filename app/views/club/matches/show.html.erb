<% content_for :title, "Match" %>

<div class="max-w-4xl mx-auto">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-xl font-semibold text-gray-900"><%= @match.cup_team.name %> vs <%= @match.opponent_name %></h1>
      <p class="text-sm text-gray-500">
        <%= @match.tournament.display_name %>
        <span class="text-gray-400">·</span>
        <%= l(@match.starts_at, format: :long) %>
        <% if @match.venue.present? %>
          <span class="text-gray-400">·</span>
          <%= @match.venue %>
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% if policy(@match).edit? %>
        <%= link_to "Edit", edit_club_match_path(@match), class: "rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-50" %>
      <% end %>
      <% if policy(@match).destroy? %>
        <%= button_to "Delete", club_match_path(@match), method: :delete, data: { turbo_confirm: "Delete this match?" }, class: "rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-500" %>
      <% end %>
    </div>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-4 mb-4">
    <div class="text-sm text-gray-500 mb-1">Status</div>
    <div class="text-sm font-semibold text-gray-900 capitalize"><%= @match.status %></div>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-4 mb-4">
    <div class="text-sm text-gray-500 mb-1">Result</div>
    <% if @match.home_score.present? && @match.away_score.present? %>
      <div class="text-2xl font-semibold text-gray-900"><%= @match.home_score %>–<%= @match.away_score %></div>
    <% else %>
      <div class="text-sm text-gray-700">—</div>
    <% end %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-4">
    <div class="text-sm text-gray-500 mb-1">Notes</div>
    <p class="text-sm text-gray-700 whitespace-pre-line"><%= @match.notes.presence || "—" %></p>
  </div>
</div>

