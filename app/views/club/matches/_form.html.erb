<%= form_with model: [:club, @match], class: "space-y-4" do |f| %>
  <% if @match.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      <div class="font-semibold mb-1">Please fix the following:</div>
      <ul class="list-disc pl-5">
        <% @match.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :tournament_id, "Tournament", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :tournament_id, policy_scope(Tournament).includes(:cup).order(year: :desc), :id, :display_name,
        { prompt: "Select a tournament" },
        class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
    <div>
      <%= f.label :cup_team_id, "Squad", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :cup_team_id, policy_scope(CupTeam).order(:name), :id, :name,
        { prompt: "Select a squad" },
        class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :opponent_name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :opponent_name, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
    <div>
      <%= f.label :venue, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :venue, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :starts_at, class: "block text-sm font-medium text-gray-700" %>
      <%= f.datetime_local_field :starts_at, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
    <div class="flex items-center gap-4 pt-6">
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <%= f.check_box :home, class: "rounded border-gray-300" %>
        Home match
      </label>
      <div class="flex items-center gap-2">
        <%= f.label :status, class: "text-sm text-gray-700" %>
        <%= f.select :status, Match.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "rounded-lg border-gray-300 text-sm" %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :home_score, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :home_score, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
    <div>
      <%= f.label :away_score, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :away_score, class: "mt-1 block w-full rounded-lg border-gray-300" %>
    </div>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :notes, rows: 4, class: "mt-1 block w-full rounded-lg border-gray-300" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <%= link_to "Cancel", club_matches_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>

