<%# Mobile topbar %>
<div class="sticky top-0 z-40 flex items-center gap-4 h-14 px-4 bg-white border-b border-gray-200 lg:hidden">
  <button type="button" data-action="sidebar#open" class="p-1.5 rounded-md text-gray-500 hover:bg-gray-100">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
    </svg>
  </button>
  <span class="text-sm font-semibold text-gray-900 truncate"><%= current_academy.name %></span>
</div>