<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="turbo-cache-control" content="no-preview">
    <title><%= content_for?(:title) ? yield(:title) + " — " : "" %><%= current_academy&.name || "SuperOnce" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full font-sans antialiased" data-controller="sidebar">

    <div class="flex h-full">
      <%# ── Sidebar ────────────────────────────────────── %>
      <%= render "shared/sidebar" %>
      <%= render "shared/mobile_sidebar_backdrop" %>

      <%# ── Main ────────────────────────────────────── %>
      <div class="flex-1 lg:pl-64 flex flex-col min-h-full">
        <%# Top bar for mobile %>
        <%= render "shared/mobile_topbar" %>

        <%# Page content %>
        <main class="flex-1 px-6 py-8" id="main-content">
          <%= yield %>
        </main>

      </div>
    </div>

  </body>
</html>
