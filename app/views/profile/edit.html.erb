<% content_for :title, "Edit profile" %>

<div class="max-w-xl mx-auto">
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-gray-900">Edit profile</h1>
  </div>

  <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-5" do |f| %>

    <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
      <h2 class="text-sm font-semibold text-gray-900">Personal information</h2>
      <div>
        <%= f.label :full_name, "Full name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :full_name, class: "input-field", placeholder: "Your full name" %>
      </div>
      <div>
        <%= f.label :email_address, "Email address", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.email_field :email_address, class: "input-field" %>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
      <div>
        <h2 class="text-sm font-semibold text-gray-900">Change password</h2>
        <p class="text-xs text-gray-400 mt-0.5">Leave blank to keep your current password.</p>
      </div>
      <div>
        <%= f.label :current_password, "Current password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.password_field :current_password, class: "input-field", autocomplete: "current-password" %>
      </div>
      <div class="grid grid-cols-2 gap-5">
        <div>
          <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.password_field :password, class: "input-field", autocomplete: "new-password" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirm", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.password_field :password_confirmation, class: "input-field", autocomplete: "new-password" %>
        </div>
      </div>
    </div>

    <% if @user.errors.any? %>
      <div class="px-4 py-3 rounded-lg bg-red-50 border border-red-200">
        <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="flex items-center gap-3">
      <%= f.submit "Save changes",
            class: "px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
      <%= link_to "Cancel", profile_path,
            class: "px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>
