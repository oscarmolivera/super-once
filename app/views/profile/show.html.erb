<% content_for :title, "My profile" %>

<div class="max-w-xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-900">My profile</h1>
    <%= link_to "Edit", edit_profile_path,
          class: "px-4 py-2 text-sm font-medium text-indigo-600 border border-indigo-200 rounded-lg hover:bg-indigo-50 transition-colors" %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center gap-4 mb-6 pb-6 border-b border-gray-100">
      <div class="w-14 h-14 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 text-xl font-semibold">
        <%= @user.full_name&.first&.upcase || @user.email_address.first.upcase %>
      </div>
      <div>
        <p class="text-base font-semibold text-gray-900"><%= @user.full_name || "No name set" %></p>
        <p class="text-sm text-gray-500"><%= @user.email_address %></p>
        <p class="text-xs text-gray-400 mt-0.5 capitalize"><%= current_membership.role %> · <%= current_academy.name %></p>
      </div>
    </div>

    <%= render "shared/setting_row", label: "Full name",  value: @user.full_name.presence || "—" %>
    <%= render "shared/setting_row", label: "Email",      value: @user.email_address %>
    <%= render "shared/setting_row", label: "Password",   value: "••••••••" %>
  </div>
</div>
