<%# locals: (item:, url:, method: :post) %>
<%= form_with model: item, url: url, method: method, class: "space-y-5" do |f| %>
  <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="sm:col-span-2">
        <%= f.label :name, "Item name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :name, class: "input-field", autofocus: true %>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_area :description, rows: 2, class: "input-field resize-none" %>
      </div>
      <div>
        <%= f.label :category, "Category", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.select :category,
              options_for_select(InventoryItem.categories.keys.map { |c| [c.humanize, c] }, item.category),
              {}, class: "input-field" %>
      </div>
      <div>
        <%= f.label :condition, "Condition", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.select :condition,
              options_for_select([["New", "new_item"], ["Good", "good"], ["Fair", "fair"], ["Poor", "poor"]], item.condition),
              {}, class: "input-field" %>
      </div>
      <div>
        <%= f.label :quantity, "Quantity", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.number_field :quantity, min: 0, class: "input-field" %>
      </div>
      <div>
        <%= f.label :unit_value, "Unit value (€)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.number_field :unit_value, step: "0.01", min: 0, class: "input-field" %>
      </div>
      <div>
        <%= f.label :acquired_on, "Acquired on", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.date_field :acquired_on, class: "input-field" %>
      </div>
      <div>
        <%= f.label :location, "Storage location", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :location, class: "input-field", placeholder: "e.g. Equipment room A" %>
      </div>
    </div>
  </div>
  <% if item.errors.any? %>
    <div class="px-4 py-3 rounded-lg bg-red-50 border border-red-200">
      <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
        <% item.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>
  <div class="flex items-center gap-3">
    <%= f.submit item.persisted? ? "Save changes" : "Add item",
          class: "px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", enterprise_inventory_items_path, class: "px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
