<% content_for :title, "Inventory" %>
<%= render "enterprise/subnav_layout" do %>

<%= render "shared/page_header",
      title: "Inventory",
      action_path: (policy(InventoryItem).new? ? new_enterprise_inventory_item_path : nil),
      action_label: "Add item" %>

<% if @low_stock > 0 %>
  <div class="mb-5 flex items-center gap-3 px-4 py-3 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm">
    <%= render "shared/icon", name: "exclamation-triangle", css: "w-4 h-4 flex-shrink-0 text-amber-500" %>
    <%= @low_stock %> item<%= @low_stock > 1 ? "s" : "" %> running low (3 or fewer remaining)
  </div>
<% end %>

<div class="space-y-5">
  <% if @items.any? %>
    <% InventoryItem.categories.keys.each do |cat| %>
      <% items = @by_cat[cat] %>
      <% next unless items&.any? %>
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-100 bg-gray-50">
          <p class="text-sm font-semibold text-gray-700"><%= cat.humanize %></p>
        </div>
        <table class="w-full text-sm">
          <thead class="border-b border-gray-100">
            <tr>
              <th class="px-5 py-2.5 text-left text-xs font-semibold text-gray-500">Item</th>
              <th class="px-5 py-2.5 text-left text-xs font-semibold text-gray-500">Qty</th>
              <th class="px-5 py-2.5 text-left text-xs font-semibold text-gray-500">Condition</th>
              <th class="px-5 py-2.5 text-left text-xs font-semibold text-gray-500">Location</th>
              <th class="px-5 py-2.5 text-left text-xs font-semibold text-gray-500">Value</th>
              <th class="px-5 py-2.5"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% items.each do |item| %>
              <tr class="hover:bg-gray-50 transition-colors <%= item.quantity <= 3 && item.quantity > 0 ? 'bg-amber-50/30' : '' %>">
                <td class="px-5 py-3.5">
                  <p class="font-medium text-gray-900"><%= item.name %></p>
                  <p class="text-xs text-gray-400"><%= item.description %></p>
                </td>
                <td class="px-5 py-3.5 font-medium <%= item.quantity == 0 ? 'text-red-600' : item.quantity <= 3 ? 'text-amber-600' : 'text-gray-900' %>">
                  <%= item.quantity %>
                </td>
                <td class="px-5 py-3.5 text-gray-500"><%= item.display_condition %></td>
                <td class="px-5 py-3.5 text-gray-500"><%= item.location.presence || "—" %></td>
                <td class="px-5 py-3.5 text-gray-500"><%= item.total_value ? number_to_currency(item.total_value, unit: "€", format: "%u%n") : "—" %></td>
                <td class="px-5 py-3.5 text-right">
                  <% if policy(item).edit? %>
                    <%= link_to edit_enterprise_inventory_item_path(item), class: "text-xs text-indigo-500 hover:underline mr-3" do %>Edit<% end %>
                  <% end %>
                  <% if policy(item).destroy? %>
                    <%= button_to enterprise_inventory_item_path(item), method: :delete,
                          data: { turbo_confirm: "Remove #{item.name}?" },
                          class: "text-xs text-red-400 hover:underline" do %>Remove<% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-200 px-5 py-12 text-center">
      <p class="text-sm text-gray-400 mb-3">No inventory items yet.</p>
      <% if policy(InventoryItem).new? %>
        <%= link_to "Add your first item", new_enterprise_inventory_item_path, class: "text-sm text-indigo-600 font-medium hover:underline" %>
      <% end %>
    </div>
  <% end %>
</div>

<% end %>
