<% content_for :title, "Player payments" %>
<%= render "enterprise/subnav_layout" do %>

<div class="space-y-5">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-xl font-semibold text-gray-900">Player payments</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= Date.new(@year, @month).strftime("%B %Y") %></p>
    </div>
    <div class="flex items-center gap-3">
      <% prev_m = Date.new(@year, @month).prev_month; next_m = Date.new(@year, @month).next_month %>
      <%= link_to enterprise_player_payments_path(month: prev_m.month, year: prev_m.year), class: "px-3 py-1.5 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50" do %>‹ <%= prev_m.strftime("%b") %><% end %>
      <%= link_to enterprise_player_payments_path(month: next_m.month, year: next_m.year), class: "px-3 py-1.5 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50" do %><%= next_m.strftime("%b") %> ›<% end %>
      <% if policy(PlayerPayment).new? %>
        <%= link_to new_enterprise_player_payment_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors" do %>
          <%= render "shared/icon", name: "plus", css: "w-4 h-4" %>
          Add payment
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-400 mb-1">Expected</p>
      <p class="text-xl font-semibold text-gray-900"><%= number_to_currency(@total_expected, unit: "€", format: "%u%n") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-400 mb-1">Collected</p>
      <p class="text-xl font-semibold text-green-700"><%= number_to_currency(@total_paid, unit: "€", format: "%u%n") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-400 mb-1">Pending</p>
      <p class="text-xl font-semibold text-amber-700"><%= number_to_currency(@total_pending, unit: "€", format: "%u%n") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-400 mb-1">Overdue</p>
      <p class="text-xl font-semibold text-red-700"><%= number_to_currency(@total_overdue, unit: "€", format: "%u%n") %></p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <% if @payments.any? %>
      <table class="w-full text-sm">
        <thead class="border-b border-gray-100">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Player</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Amount</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Due date</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @payments.each do |payment| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3.5 font-medium text-gray-900"><%= payment.player_name %></td>
              <td class="px-5 py-3.5 text-gray-900"><%= number_to_currency(payment.amount, unit: "€", format: "%u%n") %></td>
              <td class="px-5 py-3.5 text-gray-500"><%= payment.due_on.strftime("%b %d") %></td>
              <td class="px-5 py-3.5">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= { 'paid' => 'bg-green-50 text-green-700', 'overdue' => 'bg-red-50 text-red-700',
                        'pending' => 'bg-amber-50 text-amber-700', 'waived' => 'bg-gray-100 text-gray-500' }[payment.status] %>">
                  <%= payment.status.capitalize %>
                </span>
              </td>
              <td class="px-5 py-3.5 text-right flex items-center justify-end gap-3">
                <% if policy(payment).update? && !payment.status_paid? && !payment.status_waived? %>
                  <%= button_to mark_paid_enterprise_player_payment_path(payment), method: :patch,
                        class: "text-xs text-green-600 hover:underline",
                        data: { turbo_confirm: "Mark #{payment.player_name} as paid?" } do %>Mark paid<% end %>
                <% end %>
                <% if policy(payment).edit? %>
                  <%= link_to edit_enterprise_player_payment_path(payment), class: "text-xs text-indigo-500 hover:underline" do %>Edit<% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-5 py-12 text-center text-sm text-gray-400">No payment records for <%= Date.new(@year, @month).strftime("%B %Y") %>.</p>
    <% end %>
  </div>
</div>

<% end %>
