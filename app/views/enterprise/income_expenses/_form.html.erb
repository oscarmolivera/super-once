<%# locals: (entry:, url:, method: :post) %>
<%= form_with model: entry, url: url, method: method, class: "space-y-5" do |f| %>
  <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= f.label :kind, "Type", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.select :kind,
              options_for_select([["Income", "income"], ["Expense", "expense"]], entry.kind),
              {}, class: "input-field" %>
      </div>
      <div>
        <%= f.label :amount, "Amount (€)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.number_field :amount, step: "0.01", min: 0.01, class: "input-field" %>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :description, class: "input-field", placeholder: "e.g. Monthly pitch rental" %>
      </div>
      <div>
        <%= f.label :category, "Category", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.select :category,
              options_for_select(IncomeExpense.categories.keys.map { |c| [c.humanize, c] }, entry.category),
              {}, class: "input-field" %>
      </div>
      <div>
        <%= f.label :recorded_on, "Date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.date_field :recorded_on, class: "input-field" %>
      </div>
      <div>
        <%= f.label :reference, "Reference / invoice no.", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :reference, class: "input-field" %>
      </div>
    </div>
  </div>
  <% if entry.errors.any? %>
    <div class="px-4 py-3 rounded-lg bg-red-50 border border-red-200">
      <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
        <% entry.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>
  <div class="flex items-center gap-3">
    <%= f.submit entry.persisted? ? "Save changes" : "Add entry",
          class: "px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", enterprise_income_expenses_path, class: "px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
