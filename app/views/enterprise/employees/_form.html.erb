<%# locals: (employee:, url:, method: :post) %>
<%= form_with model: employee, url: url, method: method, class: "space-y-5" do |f| %>

  <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
    <h2 class="text-sm font-semibold text-gray-900">Personal information</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= f.label :full_name, "Full name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :full_name, class: "input-field", autofocus: true %>
      </div>
      <div>
        <%= f.label :employee_type, "Role", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.select :employee_type,
              options_for_select(Employee.employee_types.keys.map { |t| [t.humanize, t] }, employee.employee_type),
              {}, class: "input-field" %>
      </div>
      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.email_field :email, class: "input-field" %>
      </div>
      <div>
        <%= f.label :phone, "Phone", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.telephone_field :phone, class: "input-field" %>
      </div>
      <div>
        <%= f.label :birth_date, "Date of birth", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.date_field :birth_date, class: "input-field" %>
      </div>
      <div>
        <%= f.label :document_number, "ID / document number", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :document_number, class: "input-field" %>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
    <h2 class="text-sm font-semibold text-gray-900">Employment</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <%= f.label :hire_date, "Hire date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.date_field :hire_date, class: "input-field" %>
      </div>
      <div>
        <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.select :status,
              options_for_select([["Active", "active"], ["Inactive", "inactive"]], employee.status),
              {}, class: "input-field" %>
      </div>
      <div>
        <%= f.label :base_salary, "Base salary (€/month)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.number_field :base_salary, step: "0.01", min: 0, class: "input-field" %>
      </div>
    </div>
    <div>
      <%= f.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.text_area :notes, rows: 2, class: "input-field resize-none" %>
    </div>
  </div>

  <% if employee.errors.any? %>
    <div class="px-4 py-3 rounded-lg bg-red-50 border border-red-200">
      <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
        <% employee.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex items-center gap-3">
    <%= f.submit employee.persisted? ? "Save changes" : "Add employee",
          class: "px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to employee.persisted? ? enterprise_employee_path(employee) : enterprise_employees_path,
          "Cancel", class: "px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900" %>
  </div>

<% end %>
