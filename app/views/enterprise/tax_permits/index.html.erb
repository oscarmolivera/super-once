<% content_for :title, "Documents & permits" %>
<%= render "enterprise/subnav_layout" do %>

<%= render "shared/page_header",
      title: "Documents & permits",
      action_path: (policy(TaxPermit).new? ? new_enterprise_tax_permit_path : nil),
      action_label: "Add document" %>

<div class="space-y-5">
  <% if @expired.any? || @expiring_soon.any? %>
    <div class="space-y-2">
      <% @expired.each do |permit| %>
        <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-800 text-sm">
          <%= render "shared/icon", name: "exclamation-triangle", css: "w-4 h-4 flex-shrink-0 text-red-500" %>
          <span><strong><%= permit.name %></strong> expired on <%= permit.expires_on.strftime("%b %d, %Y") %></span>
          <% if policy(permit).edit? %>
            <%= link_to edit_enterprise_tax_permit_path(permit), class: "ml-auto text-xs font-semibold underline" do %>Renew<% end %>
          <% end %>
        </div>
      <% end %>
      <% @expiring_soon.each do |permit| %>
        <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-amber-50 border border-amber-200 text-amber-800 text-sm">
          <%= render "shared/icon", name: "exclamation-triangle", css: "w-4 h-4 flex-shrink-0 text-amber-500" %>
          <span><strong><%= permit.name %></strong> expires in <%= permit.days_until_expiry %> days (<%= permit.expires_on.strftime("%b %d") %>)</span>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <% if @permits.any? %>
      <table class="w-full text-sm">
        <thead class="border-b border-gray-100">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Document</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Reference</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Expires</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @permits.each do |permit| %>
            <% row_bg = permit.status_expired? ? 'bg-red-50/40' : permit.expiring_soon? ? 'bg-amber-50/40' : '' %>
            <tr class="hover:bg-gray-50 transition-colors <%= row_bg %>">
              <td class="px-5 py-3.5">
                <p class="font-medium text-gray-900"><%= permit.name %></p>
                <p class="text-xs text-gray-400"><%= permit.issuing_authority %></p>
              </td>
              <td class="px-5 py-3.5 text-gray-600"><%= permit.document_type.humanize %></td>
              <td class="px-5 py-3.5 text-gray-500 font-mono text-xs"><%= permit.reference_number.presence || "—" %></td>
              <td class="px-5 py-3.5 text-gray-500"><%= permit.expires_on&.strftime("%b %d, %Y") || "—" %></td>
              <td class="px-5 py-3.5">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= { 'active' => 'bg-green-50 text-green-700',
                        'expired' => 'bg-red-50 text-red-700',
                        'pending_renewal' => 'bg-amber-50 text-amber-700' }[permit.status] %>">
                  <%= permit.status.humanize %>
                </span>
              </td>
              <td class="px-5 py-3.5 text-right">
                <% if policy(permit).edit? %>
                  <%= link_to edit_enterprise_tax_permit_path(permit), class: "text-xs text-indigo-500 hover:underline mr-3" do %>Edit<% end %>
                <% end %>
                <% if policy(permit).destroy? %>
                  <%= button_to enterprise_tax_permit_path(permit), method: :delete,
                        data: { turbo_confirm: "Remove #{permit.name}?" },
                        class: "text-xs text-red-400 hover:underline" do %>Remove<% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-5 py-12 text-center text-sm text-gray-400">No documents registered yet.</p>
    <% end %>
  </div>
</div>

<% end %>
