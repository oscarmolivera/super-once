<%# locals: (permit:, url:, method: :post) %>
<%= form_with model: permit, url: url, method: method, class: "space-y-5" do |f| %>
  <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="sm:col-span-2">
        <%= f.label :name, "Document name", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :name, class: "input-field", placeholder: "e.g. Operating permit 2024", autofocus: true %>
      </div>
      <div>
        <%= f.label :document_type, "Document type", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.select :document_type,
              options_for_select(TaxPermit.document_types.keys.map { |t| [t.humanize, t] }, permit.document_type),
              {}, class: "input-field" %>
      </div>
      <div>
        <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.select :status,
              options_for_select([["Active", "active"], ["Pending renewal", "pending_renewal"], ["Expired", "expired"]], permit.status),
              {}, class: "input-field" %>
      </div>
      <div>
        <%= f.label :reference_number, "Reference number", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :reference_number, class: "input-field" %>
      </div>
      <div>
        <%= f.label :issuing_authority, "Issuing authority", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :issuing_authority, class: "input-field", placeholder: "e.g. Municipal Council" %>
      </div>
      <div>
        <%= f.label :issued_on, "Issue date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.date_field :issued_on, class: "input-field" %>
      </div>
      <div>
        <%= f.label :expires_on, "Expiry date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.date_field :expires_on, class: "input-field" %>
      </div>
    </div>
    <div>
      <%= f.label :notes, "Notes", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.text_area :notes, rows: 2, class: "input-field resize-none" %>
    </div>
  </div>
  <% if permit.errors.any? %>
    <div class="px-4 py-3 rounded-lg bg-red-50 border border-red-200">
      <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
        <% permit.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>
  <div class="flex items-center gap-3">
    <%= f.submit permit.persisted? ? "Save changes" : "Add document",
          class: "px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", enterprise_tax_permits_path, class: "px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
