<% content_for :title, "Payroll" %>
<%= render "enterprise/subnav_layout" do %>

<div class="space-y-5">
  <%# Header with period picker %>
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-xl font-semibold text-gray-900">Payroll register</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= Date.new(@year, @month).strftime("%B %Y") %></p>
    </div>
    <div class="flex items-center gap-3">
      <%# Period navigation %>
      <% prev_month = Date.new(@year, @month).prev_month %>
      <% next_month = Date.new(@year, @month).next_month %>
      <%= link_to enterprise_salaries_path(month: prev_month.month, year: prev_month.year),
            class: "px-3 py-1.5 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50" do %>
        ‹ <%= prev_month.strftime("%b") %>
      <% end %>
      <%= link_to enterprise_salaries_path(month: next_month.month, year: next_month.year),
            class: "px-3 py-1.5 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50" do %>
        <%= next_month.strftime("%b") %> ›
      <% end %>

      <% if policy(Salary).create? %>
        <%= button_to generate_month_enterprise_salaries_path,
              params: { month: @month, year: @year },
              class: "px-4 py-2 border border-indigo-200 rounded-lg text-sm font-medium text-indigo-700 hover:bg-indigo-50 transition-colors" do %>
          Generate month
        <% end %>
        <%= link_to new_enterprise_salary_path,
              class: "inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors" do %>
          <%= render "shared/icon", name: "plus", css: "w-4 h-4" %>
          Add entry
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Summary row %>
  <div class="grid grid-cols-3 gap-4">
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-400 mb-1">Total payroll</p>
      <p class="text-xl font-semibold text-gray-900"><%= number_to_currency(@total_amount, unit: "€", format: "%u%n") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-400 mb-1">Paid</p>
      <p class="text-xl font-semibold text-green-700"><%= number_to_currency(@paid_amount, unit: "€", format: "%u%n") %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs text-gray-400 mb-1">Pending</p>
      <p class="text-xl font-semibold text-amber-700"><%= number_to_currency(@pending_amount, unit: "€", format: "%u%n") %></p>
    </div>
  </div>

  <%# Salary table %>
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <% if @salaries.any? %>
      <table class="w-full text-sm">
        <thead class="border-b border-gray-100">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Employee</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Role</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Amount</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Paid on</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @salaries.each do |salary| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3.5 font-medium text-gray-900"><%= salary.employee.full_name %></td>
              <td class="px-5 py-3.5 text-gray-500"><%= salary.employee.display_type %></td>
              <td class="px-5 py-3.5 text-gray-900"><%= number_to_currency(salary.amount, unit: "€", format: "%u%n") %></td>
              <td class="px-5 py-3.5">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= salary.status_paid? ? 'bg-green-50 text-green-700' : 'bg-amber-50 text-amber-700' %>">
                  <%= salary.status.capitalize %>
                </span>
              </td>
              <td class="px-5 py-3.5 text-gray-500"><%= salary.paid_on&.strftime("%b %d, %Y") || "—" %></td>
              <td class="px-5 py-3.5 text-right">
                <% if policy(salary).update? && salary.status_pending? %>
                  <%= button_to enterprise_salary_path(salary),
                        params: { salary: { status: "paid", paid_on: Date.current } },
                        method: :patch,
                        class: "text-xs text-green-600 hover:underline mr-3",
                        data: { turbo_confirm: "Mark as paid?" } do %>
                    Mark paid
                  <% end %>
                <% end %>
                <% if policy(salary).edit? %>
                  <%= link_to edit_enterprise_salary_path(salary), class: "text-xs text-indigo-500 hover:underline" do %>Edit<% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-5 py-12 text-center">
        <p class="text-sm text-gray-400 mb-3">No salary entries for <%= Date.new(@year, @month).strftime("%B %Y") %>.</p>
        <% if policy(Salary).create? %>
          <%= button_to "Generate from employee base salaries",
                generate_month_enterprise_salaries_path,
                params: { month: @month, year: @year },
                class: "text-sm text-indigo-600 font-medium hover:underline" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<% end %>
