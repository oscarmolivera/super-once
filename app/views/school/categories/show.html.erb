<% content_for :title, @category.name %>

<div class="max-w-5xl mx-auto">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-xl font-semibold text-gray-900"><%= @category.name %></h1>
      <p class="text-sm text-gray-500">
        <%= @category.sport_school.name %>
        <% if @category.min_age || @category.max_age %>
          <span class="text-gray-400">·</span>
          Ages <%= [@category.min_age, @category.max_age].compact.join("–") %>
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% if policy(@category).edit? %>
        <%= link_to "Edit", edit_school_category_path(@category), class: "rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-50" %>
      <% end %>
      <% if policy(@category).destroy? %>
        <%= button_to "Delete", school_category_path(@category), method: :delete, data: { turbo_confirm: "Delete this category?" }, class: "rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-500" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-2">
      <div class="rounded-xl border border-gray-200 bg-white p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-gray-900">Players</h2>
          <%= link_to "Register player", new_school_player_path, class: "text-sm text-indigo-600 hover:text-indigo-700" if policy(Player.new(academy: current_academy)).new? %>
        </div>

        <% if @players.any? %>
          <div class="divide-y divide-gray-100">
            <% @players.each do |p| %>
              <div class="py-2 flex items-center">
                <div class="text-sm text-gray-900">
                  <%= link_to "#{p.last_name}, #{p.first_name}", school_player_path(p), class: "hover:underline" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No players enrolled yet.</p>
        <% end %>
      </div>
    </div>

    <div>
      <div class="rounded-xl border border-gray-200 bg-white p-4 mb-4">
        <h2 class="text-sm font-semibold text-gray-900 mb-3">Coaches</h2>
        <% if @coaches.any? %>
          <ul class="space-y-2">
            <% @coaches.each do |c| %>
              <li class="text-sm text-gray-700"><%= c.full_name %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500">No coaches assigned yet.</p>
        <% end %>
      </div>

      <div class="rounded-xl border border-gray-200 bg-white p-4">
        <h2 class="text-sm font-semibold text-gray-900 mb-3">Practice</h2>
        <%= link_to "Schedule session", new_school_practice_session_path(practice_session: { category_id: @category.id }), class: "text-sm text-indigo-600 hover:text-indigo-700" if policy(PracticeSession.new(academy: current_academy, category: @category)).new? %>
      </div>
    </div>
  </div>
</div>

