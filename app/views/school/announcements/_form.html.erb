<%= form_with model: [:school, @announcement], class: "space-y-4" do |f| %>
  <% if @announcement.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      <div class="font-semibold mb-1">Please fix the following:</div>
      <ul class="list-disc pl-5">
        <% @announcement.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :category_id, "Audience", class: "block text-sm font-medium text-gray-700" %>
    <%= f.collection_select :category_id, policy_scope(Category).order(:name), :id, :name,
      { include_blank: "Academy-wide" },
      class: "mt-1 block w-full rounded-lg border-gray-300" %>
  </div>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :title, class: "mt-1 block w-full rounded-lg border-gray-300" %>
  </div>

  <div>
    <%= f.label :body, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :body, rows: 6, class: "mt-1 block w-full rounded-lg border-gray-300" %>
  </div>

  <div>
    <%= f.label :published_at, "Publish time", class: "block text-sm font-medium text-gray-700" %>
    <%= f.datetime_local_field :published_at, class: "mt-1 block w-full rounded-lg border-gray-300" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <%= link_to "Cancel", school_announcements_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>

