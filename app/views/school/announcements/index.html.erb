<% content_for :title, "Announcements" %>

<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold text-gray-900">Announcements</h1>
    <% if policy(Announcement.new(academy: current_academy)).new? %>
      <%= link_to "New announcement", new_school_announcement_path, class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <% end %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white divide-y divide-gray-100">
    <% @announcements.each do |a| %>
      <div class="p-4">
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="text-sm font-medium text-gray-900">
              <%= link_to a.title, school_announcement_path(a), class: "hover:underline" %>
            </div>
            <div class="text-xs text-gray-500 mt-0.5">
              <%= a.category&.name || "Academy-wide" %>
              <span class="text-gray-400">·</span>
              <%= a.published_at ? l(a.published_at, format: :long) : "Draft" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if @announcements.empty? %>
      <div class="p-6 text-sm text-gray-500">No announcements yet.</div>
    <% end %>
  </div>
</div>

