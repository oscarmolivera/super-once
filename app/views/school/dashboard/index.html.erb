<% content_for :title, "School" %>

<div class="max-w-4xl mx-auto">
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center">
        <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/>
        </svg>
      </div>
      <h1 class="text-xl font-semibold text-gray-900">School</h1>
    </div>
    <p class="text-sm text-gray-500">Manage categories, players, practice sessions, attendance and announcements.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <%= link_to school_categories_path, class: "block rounded-xl border border-gray-200 bg-white p-4 hover:border-gray-300" do %>
      <div class="text-sm font-medium text-gray-900">Categories</div>
      <div class="text-sm text-gray-500 mt-1"><%= @categories.count %> total</div>
    <% end %>

    <%= link_to school_practice_sessions_path, class: "block rounded-xl border border-gray-200 bg-white p-4 hover:border-gray-300" do %>
      <div class="text-sm font-medium text-gray-900">Practice sessions</div>
      <div class="text-sm text-gray-500 mt-1">Upcoming: <%= @upcoming_sessions.count %></div>
    <% end %>

    <%= link_to school_players_path, class: "block rounded-xl border border-gray-200 bg-white p-4 hover:border-gray-300" do %>
      <div class="text-sm font-medium text-gray-900">Players</div>
      <div class="text-sm text-gray-500 mt-1">Registry</div>
    <% end %>

    <%= link_to school_announcements_path, class: "block rounded-xl border border-gray-200 bg-white p-4 hover:border-gray-300" do %>
      <div class="text-sm font-medium text-gray-900">Communication board</div>
      <div class="text-sm text-gray-500 mt-1">Announcements</div>
    <% end %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-gray-900">Upcoming sessions</h2>
      <%= link_to "Schedule", new_school_practice_session_path, class: "text-sm text-indigo-600 hover:text-indigo-700" if policy(PracticeSession.new(academy: current_academy)).new? %>
    </div>

    <% if @upcoming_sessions.any? %>
      <div class="divide-y divide-gray-100">
        <% @upcoming_sessions.each do |s| %>
          <div class="py-2 flex items-center gap-3">
            <div class="text-sm text-gray-900">
              <%= link_to s.category.name, school_category_path(s.category), class: "font-medium hover:underline" %>
              <span class="text-gray-400">·</span>
              <%= l(s.starts_at, format: :long) %>
            </div>
            <div class="ml-auto">
              <%= link_to "Attendance", attendance_school_practice_session_path(s), class: "text-sm text-indigo-600 hover:text-indigo-700" if policy(s).attendance? %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No upcoming sessions yet.</p>
    <% end %>
  </div>
</div>
