<% content_for :title, "Attendance" %>

<div class="max-w-5xl mx-auto">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-xl font-semibold text-gray-900">Attendance</h1>
      <p class="text-sm text-gray-500">
        <%= @category.name %>
        <span class="text-gray-400">·</span>
        <%= l(@practice_session.starts_at, format: :long) %>
      </p>
    </div>
    <%= link_to "Back", school_practice_session_path(@practice_session), class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>

  <%= form_with url: attendance_school_practice_session_path(@practice_session), method: :patch, class: "space-y-4" do %>
    <div class="rounded-xl border border-gray-200 bg-white divide-y divide-gray-100">
      <% @players.each do |player| %>
        <% record = @attendance_by_player_id&.dig(player.id) %>
        <div class="p-4 grid grid-cols-1 md:grid-cols-12 gap-3 items-center">
          <div class="md:col-span-4 text-sm font-medium text-gray-900">
            <%= player.last_name %>, <%= player.first_name %>
          </div>
          <div class="md:col-span-3">
            <select name="attendance[<%= player.id %>][status]" class="block w-full rounded-lg border-gray-300 text-sm">
              <% AttendanceRecord.statuses.keys.each do |k| %>
                <option value="<%= k %>" <%= "selected" if record&.status == k %>><%= k.humanize %></option>
              <% end %>
            </select>
          </div>
          <div class="md:col-span-5">
            <input type="text" name="attendance[<%= player.id %>][notes]" value="<%= record&.notes %>" placeholder="Notes (optional)"
              class="block w-full rounded-lg border-gray-300 text-sm" />
          </div>
        </div>
      <% end %>

      <% if @players.empty? %>
        <div class="p-6 text-sm text-gray-500">No players enrolled in this category.</div>
      <% end %>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Save attendance</button>
      <%= link_to "Cancel", school_practice_session_path(@practice_session), class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>

