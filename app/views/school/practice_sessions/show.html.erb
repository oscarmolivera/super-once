<% content_for :title, "Practice session" %>

<div class="max-w-5xl mx-auto">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-xl font-semibold text-gray-900"><%= @practice_session.category.name %></h1>
      <p class="text-sm text-gray-500">
        <%= l(@practice_session.starts_at, format: :long) %>
        <% if @practice_session.location.present? %>
          <span class="text-gray-400">·</span>
          <%= @practice_session.location %>
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% if policy(@practice_session).attendance? %>
        <%= link_to "Attendance", attendance_school_practice_session_path(@practice_session), class: "rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
      <% end %>
      <% if policy(@practice_session).edit? %>
        <%= link_to "Edit", edit_school_practice_session_path(@practice_session), class: "rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-50" %>
      <% end %>
      <% if policy(@practice_session).destroy? %>
        <%= button_to "Delete", school_practice_session_path(@practice_session), method: :delete, data: { turbo_confirm: "Delete this session?" }, class: "rounded-lg bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-500" %>
      <% end %>
    </div>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white p-4">
    <h2 class="text-sm font-semibold text-gray-900 mb-3">Notes</h2>
    <p class="text-sm text-gray-700 whitespace-pre-line"><%= @practice_session.notes.presence || "—" %></p>
  </div>
</div>

