<div class="space-y-6">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Subscriptions</h1>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-lg shadow p-6">
    <%= form_with url: admin_billing_subscriptions_path, method: :get, local: true, class: "flex gap-4 flex-wrap" do |f| %>
      <%= f.text_field :search, placeholder: "Search academies...", value: params[:search], class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500" %>

      <%= f.select :status,
        [["All Status", nil], ["Active", "active"], ["Past Due", "past_due"], ["Canceled", "canceled"], ["Paused", "paused"]],
        { selected: params[:status] },
        class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500" %>

      <%= f.select :plan,
        [["All Plans", nil]] + @plans.map { |p| [p.name, p.id] },
        { selected: params[:plan] },
        class: "px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500" %>

      <%= f.submit "Filter", class: "px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700" %>
    <% end %>
  </div>

  <!-- Subscriptions Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Academy</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Plan</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">MRR</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Started</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Next Renewal</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @subscriptions.each do |sub| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <p class="font-medium text-gray-900"><%= sub.academy.name %></p>
              <p class="text-sm text-gray-600"><%= sub.academy.slug %>.nubbe.net</p>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-sm font-medium capitalize">
                <%= sub.plan.name %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-3 py-1 rounded-full text-sm font-medium
                <%= case sub.status
                    when 'active' then 'bg-green-100 text-green-800'
                    when 'past_due' then 'bg-red-100 text-red-800'
                    when 'canceled' then 'bg-gray-100 text-gray-800'
                    when 'paused' then 'bg-yellow-100 text-yellow-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= sub.status.titleize %>
                <% if sub.trialing? %>
                  <span class="ml-1">(Trial)</span>
                <% end %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <p class="font-medium text-gray-900">${{ sub.mrr.round(2) }}</p>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <%= sub.created_at.strftime('%b %d, %Y') %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <% if sub.active? %>
                <%= sub.current_period_end.strftime('%b %d, %Y') %>
              <% else %>
                —
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <%= link_to "View", edit_admin_academy_path(sub.academy), class: "text-indigo-600 hover:text-indigo-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if @subscriptions.respond_to?(:total_pages) %>
    <div class="flex justify-center gap-2">
      <%#= link_to "← Prev", admin_billing_subscriptions_path(page: @subscriptions.prev_page, **filter_params), class: "px-4 py-2 border border-gray-300 rounded-lg" unless @subscriptions.first_page? %>
      <span class="px-4 py-2">Page <%= @subscriptions.current_page %> of <%= @subscriptions.total_pages %></span>
      <%#= link_to "Next →", admin_billing_subscriptions_path(page: @subscriptions.next_page, **filter_params), class: "px-4 py-2 border border-gray-300 rounded-lg" unless @subscriptions.last_page? %>
    </div>
  <% end %>
</div>
